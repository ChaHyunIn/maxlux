# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# HotelLux
HOTELLUX_SESSION_COOKIE=your_connect_sid_value
# HOTELLUX_BASE_URL=https://api.hotellux.com (Optional: override default base URL)

# Scraper Tuning
PAGING_LIMIT=20
REQUEST_DELAY_SEC=1.5
OTA_DAYS_AHEAD=14
RETENTION_MONTHS=6

# Third-party APIs
DATA_GO_KR_API_KEY=your_api_key_for_holidays

# SEO & UI
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_EXCHANGE_RATE_USD=1420.5

# Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
